# Copy this file to .streamlit/secrets.toml for local testing, or paste the
# same values into Streamlit Community Cloud > App > Settings > Secrets.
#
# Keep .streamlit/secrets.toml private. It is intentionally gitignored.

# App login gate. Strongly recommended for public Streamlit URLs because
# otherwise visitors can use your configured API keys through the app.
APP_PASSWORD = "change-me-to-a-long-random-password"

# Alternative: store a SHA-256 hash instead of plaintext.
# APP_PASSWORD_SHA256 = "..."

# Pick the provider keys you actually use:
# OPENAI_API_KEY = "sk-..."
# ANTHROPIC_API_KEY = "sk-ant-..."
# DEEPSEEK_API_KEY = "sk-..."
# OPENROUTER_API_KEY = "sk-or-..."
# DASHSCOPE_API_KEY = "sk-..."
# ZHIPU_API_KEY = "..."

# Optional data vendor key:
# ALPHA_VANTAGE_API_KEY = "..."

# Compatible/custom endpoints:
# MIMO_API_KEY = "..."
# MIMO_BASE_URL = "https://api.xiaomimimo.com/anthropic"
# LITELLM_API_KEY = "..."
# LITELLM_BASE_URL = "https://your-litellm.example.com"
# CUSTOM_OPENAI_API_KEY = "..."
# CUSTOM_OPENAI_BASE_URL = "https://your-openai-compatible.example.com/v1"

# Azure OpenAI:
# AZURE_OPENAI_API_KEY = "..."
# AZURE_OPENAI_ENDPOINT = "https://<resource>.openai.azure.com/"
# AZURE_OPENAI_DEPLOYMENT_NAME = "deployment-name"
# OPENAI_API_VERSION = "2025-03-01-preview"
